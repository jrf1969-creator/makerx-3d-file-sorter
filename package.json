{
  "name": "makerx-3d-viewer",
  "version": "1.2.0",
  "description": "MakerX Designs 3D File Viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.makerxdesigns.viewer",
    "productName": "MakerX 3D Viewer",
    "copyright": "Copyright © 2025 MakerX Designs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "app.js",
      "libs/**",
      "node_modules/adm-zip/**"
    ],
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MakerX 3D Viewer",
      "uninstallDisplayName": "MakerX 3D Viewer"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
